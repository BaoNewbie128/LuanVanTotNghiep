APP_NAME="JDM WORLD"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN
FRONTEND_URL=https://YOUR_DOMAIN
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN
APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jdm_world
DB_USERNAME=jdm_user
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.YOUR_DOMAIN

FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@YOUR_DOMAIN
MAIL_FROM_NAME="JDM WORLD"

JDM_AI_URL=http://127.0.0.1:5000
JDM_AI_DESCRIPTIONS_PATH=/var/www/jdm-world/DoAnAI/descriptions
VILAO_LLM_URL=https://api.vilao.ai/v1
VILAO_LLM_API_KEY=
VILAO_LLM_MODEL=botzalo
VILAO_LLM_CA_BUNDLE=

MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Optional. Leave empty and do not run DemoUserSeeder on a real production database.
DEMO_USER_PASSWORD=
