APP_NAME="JDM WORLD"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lvtnthanhbao.cnttstu.online
FRONTEND_URL=https://lvtnthanhbao.cnttstu.online
CORS_ALLOWED_ORIGINS=https://lvtnthanhbao.cnttstu.online
APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=stiioxwl_jdm
DB_USERNAME=stiioxwl_jdm
DB_PASSWORD=REPLACE_WITH_NEW_DATABASE_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Create this mailbox in cPanel before enabling OTP/password-reset email.
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.lvtnthanhbao.cnttstu.online
MAIL_PORT=465
MAIL_USERNAME=no-reply@lvtnthanhbao.cnttstu.online
MAIL_PASSWORD=REPLACE_WITH_EMAIL_PASSWORD
MAIL_FROM_ADDRESS=no-reply@lvtnthanhbao.cnttstu.online
MAIL_FROM_NAME="JDM WORLD"

# The AI model is hosted on Render; cPanel only proxies requests through Laravel.
JDM_AI_URL=https://jdm-car-recognition.onrender.com
JDM_AI_DESCRIPTIONS_PATH=/home/stiioxwl/lvtnthanhbao.cnttstu.online/backend/resources/ai-descriptions
JDM_AI_CONNECT_TIMEOUT=15
JDM_AI_TIMEOUT=180

VILAO_LLM_URL=https://api.vilao.ai/v1
VILAO_LLM_API_KEY=
VILAO_LLM_MODEL=botzalo
VILAO_LLM_CA_BUNDLE=

MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Set a strong value only when intentionally creating demo accounts.
DEMO_USER_PASSWORD=

